            "uid": "timescaledb"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  \"time\" AS \"time\",\n  rx_mbps AS \"RX (Mbps)\",\n  tx_mbps * -1 AS \"TX (Mbps)\"\nFROM public.net_metrics\nWHERE\n  $__timeFilter(\"time\") AND\n  device_id = '$machine_id' AND\n  iface_name = '$interface'\nORDER BY 1",
          "refId": "A"
        }
