      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  \"time\" AS \"time\",\n  cpu_load_percent AS \"CPU Load %\",\n  (ram_used_mb / NULLIF(ram_total_mb, 0) * 100) AS \"RAM Usage %\"\nFROM public.sys_metrics\nWHERE\n  $__timeFilter(\"time\") AND\n  device_id = '$machine_id'\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "CPU & RAM Utilization (sys_metrics)",
      "type": "timeseries"
    },
